# ==============================================================================
# Ambientes virtuais
# ==============================================================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Exceção: os arquivos de ambiente do e2e (tests/fixtures/configs/env/) NÃO são
# virtualenvs — são configs versionadas. A regra genérica 'env/' acima os capturava
# por engano, deixando as specs de ambiente fora do controle de versão.
!tests/fixtures/configs/env/
!tests/fixtures/configs/env/**

# ==============================================================================
# Jupyter / IPython
# ==============================================================================
.ipynb_checkpoints
profile_default/
ipython_config.py

# ==============================================================================
# Poetry
# ==============================================================================
# poetry.lock é mantido no controle de versão para garantir reprodutibilidade.
# poetry.toml contém configurações locais e não deve ser versionado.
poetry.toml

